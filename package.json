    "download:mp4s": "tsx --env-file=.env.local scripts/download-mp4s.ts",
    "enrich:cutplans": "tsx --conditions=react-server --env-file=.env.local scripts/enrich-cutplans-batch.ts",
    "build:technique-index": "tsx --conditions=react-server --env-file=.env.local scripts/build-technique-index.ts",
