{
  "name": "viral-reviewer",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "scrape:tiktok": "tsx --env-file=.env.local scripts/scrape-tiktok.ts",
    "scrape:instagram": "tsx --env-file=.env.local scripts/scrape-instagram.ts",
    "enrich": "tsx --env-file=.env.local scripts/enrich-videos.ts",
