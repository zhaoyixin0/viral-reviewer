# viral-reviewer environment variables
#
# Local dev (.env.local): copy this file + fill values. NEVER commit .env.local.
# 新 dev / 重装环境完整步骤见 docs/onboarding/local-dev-setup.md
# (含 gcloud auth ladder / smoke check / troubleshooting / secret 安全)。
# Production (Cloud Run): values are stored in Google Secret Manager and bound
# via service.yaml `valueFrom.secretKeyRef`. Bootstrap: see
# docs/deploy/cloud-run-setup.md Chapter 7 (Secret Manager) + Chapter 10
# (Cloud Scheduler OIDC, P5.3).
#
# Variable categories:
# - "secret" → bound via Secret Manager in production (NEVER in plain env)
# - "plain"  → bound as plain env in service.yaml (non-sensitive: URLs, model
#              names, SA emails)
# - "local-only" → dev convenience flags, no production binding needed
# - "auto" → set automatically by Cloud Run / GHA / Vercel runtime

# =======================================================================
# Secrets (production: Secret Manager → service.yaml secretKeyRef)
# =======================================================================

# Apify - TikTok / Instagram scraping
# (memory: 2026-05-13 token 暴露 once, P5.6 cutover 借机 rotate)
APIFY_TOKEN=

# Anthropic - Claude Opus 4.7 (review) + Haiku 4.5 (vision/enrich)
ANTHROPIC_API_KEY=

# Google Gemini - 2.5 Pro for video understanding (CutPlan IR extraction)
GOOGLE_API_KEY=

# OpenAI - Whisper for video transcription + fallback for review
OPENAI_API_KEY=

# Vercel Blob - upload storage (P5.1.b GCS swap 后 transitional / 退役)
BLOB_READ_WRITE_TOKEN=

# P5.1.b-2: HMAC-SHA256 key for browser-direct-upload completion ping signing.
# Generate: openssl rand -hex 32 (32 bytes / 64 hex / 256-bit)
# Production: gcloud secrets create upload-signing-secret (per runbook §7.1).
UPLOAD_SIGNING_SECRET=

# Cron auth - Vercel Cron legacy (P5.3 transitional; P5.7 cutover 后退役)
# Production OIDC main path uses CRON_OIDC_* below (plain env).
CRON_SECRET=

# Cron auth - manual trigger fallback (始终保留, ops 紧急路径)
ADMIN_TRIGGER_SECRET=

# =======================================================================
# Plain env (production: service.yaml `value:` direct binding)
# =======================================================================

# P5.3 Cron OIDC verify - Google Cloud Scheduler 主路径 (per runbook Chapter 10)
# AUDIENCE: Cloud Run service URL + /api/cron/trending path
#   (P5.7 cutover 后改真实 *.run.app 或 custom domain)
# SERVICE_ACCOUNT: Cloud Scheduler 用的 SA email
#   (deploy.yml yq 替换 PROJECT_ID 为真实 GCP project ID)
CRON_OIDC_AUDIENCE=https://viral-reviewer-web/api/cron/trending
CRON_OIDC_SERVICE_ACCOUNT=cloud-scheduler@your-project-id.iam.gserviceaccount.com

# P5.1.b GCS bucket name - required for /api/upload + trending snapshot read
# Dev: 用 prod bucket viral-reviewer-blob-prod 或自己创 dev bucket
# Prod: viral-reviewer-blob-prod (per service.yaml plain env)
# 缺值 → getStorage().enabled === false → upload 503 + /trending 显示空
GCS_BUCKET_NAME=

# GCS ADC chain credentials path - 仅 LOCAL DEV 需要 (prod 自动用 Cloud Run runtime SA)
# 见 docs/onboarding/local-dev-setup.md §2.3 完整 SA JSON download 流程
# 缺值 + ADC user creds → SigningError: Cannot sign data without 'client_email'
# 路径示例:
#   macOS/Linux: GOOGLE_APPLICATION_CREDENTIALS=/Users/<you>/.gcp/viral-reviewer/runtime-sa.json
#   Windows:     GOOGLE_APPLICATION_CREDENTIALS=C:\Users\<you>\.gcp\viral-reviewer\runtime-sa.json
# **永远不要 commit SA JSON** — 路径放 repo 外 ($HOME/.gcp/) 物理隔离。
GOOGLE_APPLICATION_CREDENTIALS=

# =======================================================================
# Optional model overrides (plain env; default values shown in comments)
# =======================================================================

# ANTHROPIC_MODEL=claude-opus-4-7
# VISION_MODEL=claude-haiku-4-5-20251001
# ENRICH_MODEL=claude-haiku-4-5-20251001
# HASHTAG_MODEL=claude-haiku-4-5-20251001
# TOPIC_INFERENCE_MODEL=claude-haiku-4-5-20251001
# GEMINI_VIDEO_MODEL=gemini-2.5-pro
# OPENAI_MODEL=gpt-4o

# =======================================================================
# Local-only (dev convenience, never bound in production)
# =======================================================================

# (optional) Postgres / Neon for production scale - not currently used
# DATABASE_URL=

# (optional) Upstash Redis - rate-limit backend for production (P3 #1)
# Falls back to in-memory backend when missing (dev / first deploy).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# =======================================================================
# Auto-injected by runtime (DO NOT set manually)
# =======================================================================

# GIT_SHA - GHA deploy.yml yq replaces from ${IMAGE_TAG} short SHA
#   (echoed by /api/health for image ↔ commit audit)
# PORT - Cloud Run default 8080 (service.yaml duplicates for local docker run)
# NODE_ENV - "production" by Cloud Run / Next.js auto
