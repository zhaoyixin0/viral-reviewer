; Project-local npm config — install hygiene + Windows resilience
; Generated 2026-05-13 to make install reproducible across machines.

registry=https://registry.npmjs.org/

; Suppress noise that just slows install
fund=false
audit=false
progress=false

; Big native deps (ffmpeg-static, ffprobe-static, youtube-dl-exec) download
; binaries via postinstall — default 5min isn't always enough on slow links.
fetch-timeout=600000
fetch-retries=5
fetch-retry-maxtimeout=120000

; Force Node engine match — package.json doesn't pin yet, but if it ever
; declares "engines.node" we want install to fail fast instead of silently
; producing a broken build.
engine-strict=true

; Don't ever auto-save when devs run "npm install <pkg>" without --save flag.
save-exact=false
save-prefix=^
